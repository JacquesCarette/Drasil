ifeq "$(OS)" "Windows_NT"
    TARGET_EXTENSION=.exe
    CSC=csc
else
    UNAME_S := $(shell uname -s)
    ifeq ($(UNAME_S), Linux)
        TARGET_EXTENSION=
        CSC=mcs
    endif
    ifeq ($(UNAME_S), Darwin)
        TARGET_EXTENSION=
        CSC=mcs
    endif
endif

# Generated by Drasil v0.1-alpha

# Project Name: OOTest

# Project Purpose: Tests various aspects of general object functionality

build: OOTest$(TARGET_EXTENSION)

OOTest$(TARGET_EXTENSION): OOTest.cs
	$(CSC) -out:OOTest$(TARGET_EXTENSION) OOTest.cs

run: build
	./OOTest$(TARGET_EXTENSION) $(RUNARGS)

.PHONY: build run
