build: OOVector$(TARGET_EXTENSION)

OOVector$(TARGET_EXTENSION): OOVector.hpp OOVector.cpp
	"$(CXX)" OOVector.cpp --std=c++11 -o OOVector$(TARGET_EXTENSION)

run: build
	./OOVector$(TARGET_EXTENSION) $(RUNARGS)

.PHONY: build run
